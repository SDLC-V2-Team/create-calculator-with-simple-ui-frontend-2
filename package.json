{
  "name": "scientific-calculator",
  "version": "1.0.0",
  "description": "A modular scientific calculator extending a basic calculator engine via a function registry pattern (ADR-001).",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "vite",
    "start": "node dist/index.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts"
  },
  "keywords": [
    "calculator",
